{
  "ConnectionStrings": {
    "Default": "Data Source=products.db"
  },
  "InventoryService": {
    "BaseUrl": "http://localhost:5000/mock/",
    "RetryCount": 3,
    "TimeoutSeconds": 5,
    "CacheTtlSeconds": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
